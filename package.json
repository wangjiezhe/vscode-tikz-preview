{
  "name": "vscode-tikz-preview",
  "displayName": "TikZ Preview",
  "description": "Preview tikz lively like KtikZ",
  "version": "0.3.2",
  "license": "MIT",
  "publisher": "wangjiezhe",
  "author": {
    "name": "Jiezhe Wang"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wangjiezhe/vscode-tikz-preview"
  },
  "bugs": {
    "url": "https://github.com/wangjiezhe/vscode-tikz-preview/issues"
  },
  "homepage": "https://github.com/wangjiezhe/vscode-tikz-preview#readme",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "extensionDependencies": [
    "jock.svg"
  ],
  "keywords": [
    "latex",
    "tikz",
    "math",
    "pgfplot",
    "pdf",
    "svg",
    "preview",
    "visualization",
    "render"
  ],
  "categories": [
    "Visualization",
    "Programming Languages",
    "Education",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.tikz",
    "workspaceContains:**/*.pgf",
    "workspaceContains:**/*.tkz"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tikz-preview.preview",
        "title": "TikZ: Preview",
        "icon": "$(zap)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tikz-preview.preview",
          "when": "resourceExtname == .tikz || resourceExtname == .pgf || resourceExtname == .tkz",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TikZ Preview",
      "properties": {
        "tikz-preview.latexCommand": {
          "type": "string",
          "default": "pdflatex",
          "description": "LaTeX compiler command (pdflatex, lualatex, xelatex, etc.)"
        },
        "tikz-preview.shellEscape": {
          "type": "boolean",
          "default": false,
          "description": "Pass -shell-escape flag to the LaTeX compiler"
        },
        "tikz-preview.templatePath": {
          "type": "string",
          "default": "",
          "description": "Path to a .pgs template file. Leave empty to use the bundled default template."
        },
        "tikz-preview.templatePlaceholder": {
          "type": "string",
          "default": "<>",
          "description": "String in the template that will be replaced with the document content."
        },
        "tikz-preview.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open preview when switching to a TikZ file."
        },
        "tikz-preview.autoOpenExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [".tikz", ".pgf", ".tkz"],
          "description": "File extensions that trigger automatic preview."
        },
        "tikz-preview.previewMode": {
          "type": "string",
          "enum": ["pdf", "svg"],
          "default": "pdf",
          "description": "Preview mode: 'pdf' uses the built-in PDF.js viewer, 'svg' converts via pdftocairo/pdf2svg and opens in the jock.svg extension."
        },
        "tikz-preview.svgConverter": {
          "type": "string",
          "enum": ["pdftocairo", "pdf2svg"],
          "default": "pdftocairo",
          "description": "PDF-to-SVG converter command used when previewMode is 'svg'."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run copy-pdfjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run copy-pdfjs",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "copy-pdfjs": "node scripts/copy-pdfjs.js"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "pdfjs-dist": "^6.0.227"
  }
}
